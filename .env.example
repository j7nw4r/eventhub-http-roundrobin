# Copy to .env and fill in. The program reads these env vars directly
# (clap `env = ...`), so `set -a; source .env; set +a` then `cargo run` works.

# Easiest: one connection string from the Azure portal (a Send policy is enough).
# If it has no EntityPath, also set EVENTHUB_NAME below.
EVENTHUB_CONNECTION_STRING='Endpoint=sb://NS.servicebus.windows.net/;SharedAccessKeyName=Send;SharedAccessKey=REPLACE_ME;EntityPath=myhub'

# --- OR configure discretely instead of a connection string ---
# EVENTHUB_FQDN='mynamespace.servicebus.windows.net'
# EVENTHUB_NAME='myhub'
# EVENTHUB_SAS_KEY_NAME='Send'
# EVENTHUB_SAS_KEY='REPLACE_ME'
